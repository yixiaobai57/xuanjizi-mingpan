/* pages/history/index.wxss v1.0.0 */
.container {
  min-height: 100vh;
  background: #1a1a2e;
  padding: 30rpx;
  box-sizing: border-box;
}

.header {
  padding: 20rpx 0 30rpx;
}
.title {
  font-size: 40rpx;
  color: #c9a96e;
  font-weight: 700;
}
.subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #666666;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-card {
  position: relative;
  background: #16213e;
  border-radius: 16rpx;
  padding: 28rpx;
  border-left: 6rpx solid #c9a96e;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.day-master {
  font-size: 32rpx;
  color: #c9a96e;
  font-weight: 700;
}
.time {
  font-size: 22rpx;
  color: #777777;
}

.card-meta {
  margin-top: 12rpx;
}
.meta-text {
  font-size: 24rpx;
  color: #aaaaaa;
}

.card-preview {
  margin-top: 16rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 10rpx;
  padding: 16rpx;
}
.preview-text {
  font-size: 26rpx;
  color: #cccccc;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-arrow {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #555555;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}
.load-btn {
  font-size: 26rpx;
  color: #c9a96e;
  padding: 16rpx 40rpx;
  border: 2rpx solid rgba(201,169,110,0.3);
  border-radius: 40rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.empty-icon {
  font-size: 80rpx;
  color: #333333;
  margin-bottom: 30rpx;
}
.empty-text {
  font-size: 30rpx;
  color: #666666;
  margin-bottom: 16rpx;
}
.empty-hint {
  font-size: 24rpx;
  color: #444444;
}