/* pages/profile/index.wxss v0.6.0 */
.container {
  min-height: 100vh;
  background: #1a1a2e;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

/* 用户信息 */
.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}
.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #c9a96e;
}
.nickname {
  margin-top: 20rpx;
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 600;
}

/* 通用卡片 */
.card {
  background: #16213e;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}
.card-title {
  font-size: 30rpx;
  color: #c9a96e;
  font-weight: 600;
}

/* 订阅状态 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.status-tag {
  font-size: 26rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}
.status-tag.active {
  background: rgba(201, 169, 110, 0.2);
  color: #c9a96e;
}
.status-tag.inactive {
  background: rgba(255, 255, 255, 0.1);
  color: #999999;
}
.sub-detail {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.sub-plan {
  font-size: 28rpx;
  color: #ffffff;
}
.sub-expire {
  font-size: 24rpx;
  color: #999999;
}
.sub-empty {
  margin-top: 20rpx;
}
.sub-hint {
  font-size: 26rpx;
  color: #999999;
}

/* 购买按钮 */
.btn-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}
.btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border-radius: 16rpx;
}
.btn-monthly {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  border: 2rpx solid #c9a96e;
}
.btn-yearly {
  background: linear-gradient(135deg, #c9a96e, #8b6914);
  position: relative;
}
.btn-title {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}
.btn-price {
  font-size: 28rpx;
  color: #c9a96e;
  font-weight: 600;
}
.btn-yearly .btn-price {
  color: #ffffff;
}
.btn-badge {
  position: absolute;
  top: -12rpx;
  right: 20rpx;
  background: #e74c3c;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

/* 菜单 */
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}
.menu-label {
  font-size: 28rpx;
  color: #ffffff;
}
.menu-arrow {
  font-size: 28rpx;
  color: #666666;
}
