/* 玄机算命 · 全局样式 v0.1.0 */
/* 玄学主题：深色背景 + 金色主色调 + 白色文字 */

page {
  background-color: #1a1a2e;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
    "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 主色调：金色 */
.primary-color {
  color: #c9a96e;
}

.primary-bg {
  background-color: #c9a96e;
}

.primary-border {
  border-color: #c9a96e;
}

/* 文字层级 */
.text-white {
  color: #ffffff;
}

.text-gold {
  color: #c9a96e;
}

.text-muted {
  color: rgba(255, 255, 255, 0.5);
}

/* 卡片 */
.card {
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 24rpx;
  border: 1rpx solid rgba(201, 169, 110, 0.2);
}

/* 按钮 */
.btn-primary {
  background-color: #c9a96e;
  color: #1a1a2e;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  text-align: center;
  font-weight: 600;
  font-size: 32rpx;
}

.btn-primary:active {
  opacity: 0.8;
}

/* 全局安全区 */
.safe-area {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
