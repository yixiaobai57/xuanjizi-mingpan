# 微信小程序项目 .gitignore

# 依赖
node_modules/
miniprogram_npm/

# 系统文件
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE / 编辑器
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# 日志
*.log
npm-debug.log*

# 临时文件
temp/
*.tmp
*.temp

# 输出文件夹（中间产物/本地输出）
output/

# 私有配置（包含 AppID 等敏感信息）
project.private.config.json

# 打包产物
*.zip
dist/
build/
